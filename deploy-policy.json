{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3Deploy",
            "Effect": "Allow",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::ai-2026-project-lonestar",
                "arn:aws:s3:::ai-2026-project-lonestar/*",
                "arn:aws:s3:::rus-portfolio-prod",
                "arn:aws:s3:::rus-portfolio-prod/*",
                "arn:aws:s3:::nebius-projects",
                "arn:aws:s3:::nebius-projects/*"
            ]
        },
        {
            "Sid": "LambdaUpdate",
            "Effect": "Allow",
            "Action": [
                "lambda:UpdateFunctionCode",
                "lambda:GetFunction"
            ],
            "Resource": "arn:aws:lambda:us-east-1:901779867920:function:*"
        },
        {
            "Sid": "CloudFrontInvalidation",
            "Effect": "Allow",
            "Action": "cloudfront:CreateInvalidation",
            "Resource": [
                "arn:aws:cloudfront::901779867920:distribution/E3IA5ZUL2HT0NT",
                "arn:aws:cloudfront::901779867920:distribution/E6LY7PZWUOBBP",
                "arn:aws:cloudfront::901779867920:distribution/E3K7BNEXGNYAIR"
            ]
        }
    ]
}
